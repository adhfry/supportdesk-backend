// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

// Enum untuk Role User
enum Role {
  USER
  ADMIN
}

// Enum untuk Status Tiket
enum TicketStatus {
  OPEN
  ASSIGNED
  IN_PROGRESS
  RESOLVED
  CLOSED
}

// Model untuk tabel users
model User {
  id         Int      @id @default(autoincrement())
  name       String   @db.VarChar(100)
  email      String   @unique @db.VarChar(100)
  password   String   @db.VarChar(255)
  role       Role     @default(USER)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // Relasi: Tiket yang dibuat oleh User ini
  tickets         Ticket[] @relation("UserTickets")
  
  // Relasi: Tiket yang ditugaskan kepada Admin ini (jika role-nya ADMIN)
  assigned_tickets Ticket[] @relation("AdminTickets")

  @@map("users") // Mengubah nama tabel di MySQL menjadi lowercase plural
}

// Model untuk tabel tickets
model Ticket {
  id                Int          @id @default(autoincrement())
  ticket_number     String       @unique @db.VarChar(20) // Contoh: TCK-0001
  subject           String       @db.VarChar(255)
  description       String       @db.Text
  room_id           String       @unique @db.VarChar(100) // UUID untuk Firebase RTDB
  status            TicketStatus @default(OPEN)
  created_at        DateTime     @default(now())
  updated_at        DateTime     @updatedAt

  // Relasi ke User pembuat tiket
  user_id           Int
  user              User         @relation("UserTickets", fields: [user_id], references: [id])

  // Relasi ke Admin yang menangani (Nullable karena awalnya belum ada yang menangani)
  assigned_admin_id Int?
  assigned_admin    User?        @relation("AdminTickets", fields: [assigned_admin_id], references: [id])

  @@map("tickets") // Mengubah nama tabel di MySQL menjadi lowercase plural
}
